# Supabase Configuration
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... # Your anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ... # Your service role key (keep secret!)

# Optional: Sentry for error tracking (can add later)
# NEXT_PUBLIC_SENTRY_DSN=

# Optional: PostHog for analytics (can add later) 
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:1994
NEXT_PUBLIC_APP_NAME=Survey Platform