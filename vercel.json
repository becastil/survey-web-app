{
  "framework": "nextjs",
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "npm run build",
  "env": {
    "NEXT_PUBLIC_USE_MOCK_DATA": "true",
    "NEXT_PUBLIC_APP_NAME": "Healthcare Survey Dashboard",
    "NEXT_PUBLIC_APP_URL": "$VERCEL_URL",
    "NEXT_PUBLIC_SUPABASE_URL": "https://placeholder.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "placeholder-anon-key",
    "NEXT_PUBLIC_ARCHON_API_URL": "DUMMY_http://localhost:8000/api",
    "NEXT_PUBLIC_ARCHON_WS_URL": "DUMMY_ws://localhost:8000/ws",
    "ARCHON_API_KEY": "DUMMY_archon_api_key"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_USE_MOCK_DATA": "true",
      "NODE_OPTIONS": "--max-old-space-size=4096",
      "SKIP_ENV_VALIDATION": "1"
    }
  },
  "functions": {
    "app/api/auth/callback/route.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}